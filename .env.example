BETTER_GOV_ALLOWED_EMAIL_DOMAIN=university.edu
BETTER_GOV_APP_URL=http://127.0.0.1:8080

# Local development:
# Keep this on to show the OTP code in the UI and console when no mail provider is configured.
# In development, this also allows any email under BETTER_GOV_ALLOWED_EMAIL_DOMAIN to sign in.
BETTER_GOV_DEV_AUTH_CODES=1

# Production email delivery:
# Set both of these to send real sign-in codes through Resend.
RESEND_API_KEY=
BETTER_GOV_EMAIL_FROM=better-gov <noreply@example.com>

# Optional:
BETTER_GOV_EMAIL_REPLY_TO=

# AI explainer providers:
# Leave these empty if you do not want live AI responses yet.
BETTER_GOV_AI_PROVIDER_ORDER=gemini,openai,grok
BETTER_GOV_OPENAI_API_KEY=
BETTER_GOV_OPENAI_MODEL=gpt-4o-mini
BETTER_GOV_GEMINI_API_KEY=
BETTER_GOV_GEMINI_MODEL=gemini-2.5-flash
BETTER_GOV_GROK_API_KEY=
BETTER_GOV_GROK_MODEL=grok-2-latest
